# Privy
VITE_PRIVY_APP_ID=your_privy_app_id
VITE_TELEGRAM_BOT_USERNAME=your_bot_username

# Hyperliquid
VITE_HYPERLIQUID_TESTNET=false

# Builder Code
VITE_BUILDER_ADDRESS=0xYOUR_BUILDER_ADDRESS
VITE_BUILDER_FEE=50

# Supabase
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
CRON_SECRET=your_vercel_cron_secret

# Telegram notifications worker
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
NOTIFICATION_POLL_INTERVAL_MS=15000
NOTIFICATION_DELIVERY_BATCH_SIZE=50
NOTIFICATION_RUN_ONCE=false

# On-Ramp
VITE_ONRAMP_URL=your_onramp_redirect_url
ONRAMP_BASE_URL=http://your_vps_static_ip:8080
ONRAMP_PROXY_TOKEN=shared_secret_between_vercel_and_proxy
ONRAMP_SERVICE_ID=your_onramp_service_id
ONRAMP_SYMBOL=RUB-USDT
ONRAMP_PROVIDER_SYMBOL=RUB-USDT
ONRAMP_NETWORK=TRC20
ONRAMP_RETURN_URL=https://your-mini-app-domain/account/deposit

# On-Ramp proxy only, not needed in Vercel once provider calls go through the VPS.
ONRAMP_PROVIDER_BASE_URL=https://moonlander-dev.tsunami.cash/api/v2
ONRAMP_CLIENT_ID=your_provider_client_id
ONRAMP_SECRET=your_provider_secret

# Support
VITE_SUPPORT_FAQ_URL=
