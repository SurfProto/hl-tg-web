{
  "extends": "@repo/typescript-config/react.json",
  "compilerOptions": {
    "outDir": "./dist",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["src"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/test/**"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
