{
  "buildCommand": "pnpm build",
  "outputDirectory": "apps/tg-mini-app/dist",
  "framework": "vite",
  "installCommand": "pnpm install",
  "crons": [
    { "path": "/api/rewards/weekly-raffle", "schedule": "5 0 * * 1" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
